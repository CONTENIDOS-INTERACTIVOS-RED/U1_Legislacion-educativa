{"remainingRequest":"/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/node_modules/thread-loader/dist/cjs.js!/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/node_modules/babel-loader/lib/index.js!/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/node_modules/cache-loader/dist/cjs.js??ref--0-0!/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/src/views/curso/Tema3.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/src/views/curso/Tema3.vue","mtime":1737944213752},{"path":"/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/babel.config.js","mtime":1737944213648},{"path":"/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/node_modules/thread-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/runner/work/U1_Legislacion-educativa/U1_Legislacion-educativa/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Tema3.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAyLA,OAAA,aAAA,MAAA,0CAAA;AACA,eAAA;AACA,EAAA,IAAA,EAAA,OADA;AAEA,EAAA,UAAA,EAAA;AACA,IAAA,aAAA,EAAA;AADA,GAFA;AAKA,EAAA,IAAA,EAAA;AAAA,WAAA;AACA,MAAA,YAAA,EAAA;AACA,QAAA,IAAA,EACA,yEAFA;AAGA,QAAA,MAAA,EAAA,gBAHA;AAIA,QAAA,YAAA,EACA,8EALA;AAMA,QAAA,gBAAA,EAAA,IANA;AAOA,QAAA,SAAA,EAAA,CACA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EACA,yEAHA;AAIA,UAAA,iBAAA,EAAA,IAJA;AAKA,UAAA,QAAA,EAAA,CACA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,wCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WADA,EAMA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EACA,+DAHA;AAIA,YAAA,UAAA,EAAA;AAJA,WANA,EAYA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,yDAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAZA,EAiBA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,6BAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAjBA,CALA;AA4BA,UAAA,gBAAA,EAAA,sCA5BA;AA6BA,UAAA,kBAAA,EAAA;AA7BA,SADA,EAgCA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EACA,oEAHA;AAIA,UAAA,iBAAA,EAAA,IAJA;AAKA,UAAA,QAAA,EAAA,CACA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,sBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WADA,EAEA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,sBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAFA,EAGA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,sBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAHA,EAIA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,sBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAJA,CALA;AAWA,UAAA,gBAAA,EAAA,sCAXA;AAYA,UAAA,kBAAA,EAAA;AAZA,SAhCA,EA8CA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EACA,4EAHA;AAIA,UAAA,iBAAA,EAAA,IAJA;AAKA,UAAA,QAAA,EAAA,CACA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,mCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WADA,EAMA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,2BAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WANA,EAOA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,uBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAPA,EAQA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,2BAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WARA,CALA;AAeA,UAAA,gBAAA,EAAA,sCAfA;AAgBA,UAAA,kBAAA,EAAA;AAhBA,SA9CA,EAgEA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EACA,8EAHA;AAIA,UAAA,iBAAA,EAAA,IAJA;AAKA,UAAA,QAAA,EAAA,CACA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,uCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WADA,EAMA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,kDAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WANA,EAWA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,2CAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAXA,EAgBA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,2CAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAhBA,CALA;AA2BA,UAAA,gBAAA,EAAA,sCA3BA;AA4BA,UAAA,kBAAA,EAAA;AA5BA,SAhEA,EA8FA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EAAA,+CAFA;AAGA,UAAA,iBAAA,EAAA,IAHA;AAIA,UAAA,QAAA,EAAA,CACA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,gCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WADA,EAMA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,6CAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WANA,EAWA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,yDAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAXA,EAgBA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,uCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAhBA,CAJA;AA0BA,UAAA,gBAAA,EAAA,sCA1BA;AA2BA,UAAA,kBAAA,EAAA;AA3BA,SA9FA,CAPA;AAmIA,QAAA,sBAAA,EAAA,uCAnIA;AAoIA,QAAA,uBAAA,EACA;AArIA;AADA,KAAA;AAAA,GALA;AA8IA,EAAA,OA9IA,qBA8IA;AAAA;;AACA,SAAA,SAAA,CAAA,YAAA;AACA,MAAA,KAAA,CAAA,WAAA;AACA,KAFA;AAGA;AAlJA,CAAA","sourcesContent":["<template lang=\"pug\">\n.curso-main-container.pb-3\n  BannerInterno(:subTitulo=\"'3. Decreto 1075 del 2015 (Decreto Reglamentario Único del Sector Educación)'\")\n  .container.tarjeta.tarjeta--blanca.p-4.p-md-5\n    \n\n    p.mb-4 Es momento de explorar el Decreto 1075 de 2015, también conocido como el Decreto Reglamentario Único del Sector Educación. Este tema le permitirá comprender cómo se organiza y regula el sistema educativo en Colombia, a través de un marco normativo detallado y estructurado.\n\n    .row.mb-4\n      .d-none.d-xl-block.col-xl-4.mx-auto.mt-4.mt-xl-0(data-aos=\"fade-right\")\n        img(src='@/assets/curso/unidad/img-42.png', alt='Texto que describa la imagen')  \n      .col-12.col-xl-8.d-flex.flex-column\n        .d-flex.align-items-start.bg-amarillo.p-4.mb-4(data-aos=\"fade-up\")\n          img.me-3(style=\"width: 90px\" src='@/assets/curso/unidad/img-43.svg', alt='Texto que describa la imagen')\n          .d-flex.flex-column\n            p.pe-xl-3.mb-0 A través de este tema, se le invita a conocer su propósito, estructura y el impacto que tiene en la gestión y regulación de la educación. Prepárese para descubrir cómo este decreto unifica y organiza las normativas para fortalecer el sector educativo en Colombia.\n        p.mb-4 Visualice por un momento, que se encuentra frente a un manual que explica todo lo necesario para que el sistema educativo de un país funcione de manera ordenada y eficiente. Ese es el propósito del Decreto 1075 del 2015, conocido como el Decreto Único Reglamentario del Sector Educación. Este decreto se presenta como una herramienta integral que organiza, simplifica y regula todas las normas relacionadas con la educación en Colombia, asegurando que el sistema educativo sea accesible, equitativo y de calidad.\n        .bg-gris.p-4(data-aos=\"fade-up\")\n          span <b>¿Por qué es importante?</b> Este decreto no solo tiene la finalidad de reunir todas las normativas relacionadas con la educación, sino que también busca garantizar que las leyes sean claras y accesibles para todos los involucrados en la educación: desde estudiantes hasta autoridades educativas y docentes. De esta manera, se facilita la implementación de políticas educativas y se promueve una educación inclusiva, equitativa y de calidad. \n\n    p.mb-4 El Decreto 1075 está organizado en varios títulos que cubren todos los aspectos claves del sistema educativo colombiano. Se puede dividir en cuatro grandes bloques:\n\n    .row.mb-4\n      .col-12.col-lg-8(data-aos=\"fade-right\")\n        AcordionA(tipo=\"b\")\n          .div(titulo=\"Disposiciones generales\")\n            p Se explican los principios fundamentales de la educación en Colombia, asegurando que esta sea democrática, pluralista, y respetuosa de los derechos humanos.\n          .div(titulo=\"Organización del servicio educativo\")\n            p Este bloque describe cómo se organiza la educación en diferentes niveles (preescolar, básica, media y superior) y modalidades (formal, no formal e informal), asegurando que todos los niveles estén claramente definidos.\n          .div(titulo=\"Garantías de calidad educativa\")\n            p Aquí se establece cómo garantizar que la educación sea de calidad, a través de procesos de evaluación, estándares y mecanismos de control.\n          .div(titulo=\"Disposiciones administrativas y financieras\")\n            p Regula cómo se deben administrar y financiar los recursos educativos, además de definir el papel de las entidades responsables en la gestión educativa.\n      .col-12.col-lg-4.d-none.d-lg-block(data-aos=\"fade-left\")\n        img(src='@/assets/curso/unidad/img-44.png', alt='Texto que describa la imagen')\n\n    .row.mb-4\n      .d-none.d-xl-block.col-xl-4.mx-auto.mt-4.mt-xl-0(data-aos=\"fade-right\")\n        img(src='@/assets/curso/unidad/img-45.png', alt='Texto que describa la imagen')  \n      .col-12.col-xl-8.d-flex.flex-column\n        .d-flex.align-items-start.bg-amarillo.p-4.mb-4(data-aos=\"fade-up\")\n          img.me-3(style=\"width: 90px\" src='@/assets/curso/unidad/img-46.svg', alt='Texto que describa la imagen')\n          .d-flex.flex-column\n            p.pe-xl-3.mb-0 El Decreto 1075 del 2015, no se limita a ser un simple documento legal; es una herramienta clave para asegurar que todos los ciudadanos puedan acceder a una educación de calidad. Su estructura clara y organizada, establece las bases para un sistema educativo eficiente, lo que facilita su implementación y ejecución en todos los niveles.  \n        p.mb-4 Al comprender el propósito y la organización de este decreto, se puede observar cómo un marco normativo bien diseñado, tiene un impacto directo y positivo en la calidad de la educación y, en consecuencia, en la vida de las personas. Este enfoque estructurado permite que las políticas educativas sean más efectivas, garantizando una educación accesible y de calidad para todos.\n\n    #t_3_1.titulo-segundo\n      div.d-flex\n        span.me-3 3.1  \n        h2 Marco normativo y su importancia en el sector educativo\n\n    p.mb-4 Suponga que el sistema educativo de un país es como una máquina compleja, con cientos de piezas que deben funcionar en perfecta armonía. <b>¿Qué garantiza que estas piezas no solo encajen, sino que trabajen juntas para lograr un propósito común?</b> Esa guía es el marco normativo, y en Colombia, el Decreto 1075 del 2015, se erige como una pieza clave en esta maquinaria educativa.\n\n    .row.mb-4\n\n      .col-12.col-xl-8.d-flex.flex-column\n        p.mb-4 Este decreto no es simplemente un conjunto de reglas; es el \"manual de instrucciones\" que asegura que todos los actores del sistema educativo, estudiantes, docentes, instituciones y el Estado, puedan desempeñar su papel de manera clara y efectiva. Define cómo se organizan las instituciones, cómo se diseñan los currículos, cómo se evalúa a los estudiantes y, lo más importante, cómo se asegura que todos tengan acceso a una educación de calidad. Así, cumple con el mandato del Artículo 67 de la Constitución, que consagra la educación como un derecho fundamental y un servicio público con función social.\n        p.mb-4 Ahora, piense en esto:\n        .d-flex.align-items-start.bg-azul.p-4(data-aos=\"fade-up\")\n          img.me-3(style=\"width: 90px\" src='@/assets/curso/unidad/img-47.svg', alt='Texto que describa la imagen')\n          .d-flex.flex-column\n            p.pe-xl-3.mb-0 ¿Qué pasaría si no existiera un <b>marco normativo sólido</b>? El acceso a la educación podría depender de factores desiguales, y no habría garantías de calidad ni equidad. Este decreto, al establecer lineamientos claros, no solo organiza el sector educativo, sino que lo conecta con los principios de equidad, inclusión y calidad que sustentan el desarrollo social y humano.\n\n      .d-none.d-xl-block.col-xl-4.mx-auto.mt-4.mt-xl-0(data-aos=\"fade-left\")\n        img(src='@/assets/curso/unidad/img-48.png', alt='Texto que describa la imagen')  \n\n\n    .row.mb-4\n      .col-4.d-none.d-xl-block(data-aos=\"fade-right\")\n        img(src='@/assets/curso/unidad/img-49.png', alt='Texto que describa la imagen')\n      .col-12.col-xl-8\n        p.mb-4 Un aspecto interesante del Decreto 1075 es cómo promueve la innovación. Por ejemplo, gracias a sus disposiciones, se fomenta la flexibilidad en las modalidades de enseñanza, como la educación virtual y semipresencial. Estas opciones no solo amplían el acceso, sino que permiten adaptarse a las necesidades de poblaciones diversas: estudiantes que trabajan, viven en zonas rurales o tienen condiciones especiales. <b>¿Puede ver cómo esto transforma vidas?</b>\n        .bg-amarillo.p-4.mb-4(data-aos=\"fade-up\")\n          span Este marco normativo no es solo un documento técnico; es una <b>herramienta</b> que materializa la visión de un país donde la educación es una oportunidad real para todos. Invita a reflexionar sobre cómo las leyes, aunque parezcan distantes, tienen un impacto directo en tu entorno, en las instituciones educativas y, sobre todo, en las personas.\n        span Ahora que ha explorado el marco normativo y su importancia en el sector educativo, el siguiente paso es conocer las Normas Generales para el Sector Educativo. Este tema le permitirá entender cómo se regula la organización, gestión y evaluación dentro de las instituciones educativas.\n    \n    #t_3_2.titulo-segundo\n      div.d-flex\n        span.me-3 3.2  \n        h2 Normas generales para el sector educativo\n\n    p.text-bold.mb-4 Antes de profundizar en las Normas Generales para el Sector Educativo, reflexione por un momento: ¿cómo se asegura que las instituciones educativas funcionen de manera ordenada y eficiente? \n\n    .row.mb-4\n      .d-none.d-xl-block.col-xl-4.mx-auto.mt-4.mt-xl-0(data-aos=\"fade-right\")\n        img(src='@/assets/curso/unidad/img-50.png', alt='Texto que describa la imagen')  \n\n      .col-12.col-xl-8.d-flex.flex-column\n        .d-flex.align-items-start.bg-gris.p-4.mb-4(data-aos=\"fade-up\")\n          img.me-3(style=\"width: 90px\" src='@/assets/curso/unidad/img-51.svg', alt='Texto que describa la imagen')\n          .d-flex.flex-column\n            p.pe-xl-3.mb-0  Este tema le permitirá explorar las disposiciones claves que garantizan la calidad, la equidad y el correcto funcionamiento del sistema educativo en Colombia. ¡Descubra cómo estas normas impactan directamente en el aprendizaje y desarrollo de los estudiantes!\n        span La organización y gestión de las instituciones educativas, son elementos esenciales para el funcionamiento eficiente del sistema educativo colombiano. Estos aspectos, regulados por el Decreto 1075 del 2015, aseguran que cada institución opere de manera estructurada y coherente, con los principios establecidos en la Constitución de 1991. Comprender cómo se organizan y gestionan las instituciones educativas permite apreciar la importancia de un marco normativo sólido que promueva una educación de calidad, inclusiva y equitativa para todos los ciudadanos.\n\n    .row.mb-4\n      .col-12.col-xl-8\n        .bg-azul.p-4.mb-4(data-aos=\"fade-up\")\n          span Una organización eficiente garantiza que los recursos se utilicen de manera óptima, facilitando la implementación de programas educativos que respondan a las necesidades de los estudiantes. Por ejemplo, una distribución adecuada de personal docente y recursos materiales asegura que todas las áreas de conocimiento sean cubiertas de manera efectiva, promoviendo un aprendizaje integral (Decreto 1075, 2015).\n        span Además, una gestión transparente y participativa fomenta la confianza entre todos los actores del sistema educativo, incluyendo docentes, estudiantes, padres de familia y autoridades. Esto se traduce en un ambiente educativo donde las decisiones se toman de manera colaborativa, reflejando las necesidades y expectativas de la comunidad educativa.\n      .d-none.d-xl-block.col-xl-4(data-aos=\"fade-left\")\n        img(src='@/assets/curso/unidad/img-52.png', alt='Texto que describa la imagen')\n\n    .row.mb-4\n      .d-flex.align-items-center\n        div.d-flex.align-items-center.bg-amarillo.px-3.py-4\n          img.me-4(style=\"width: 90px\" src='@/assets/curso/unidad/img-53.svg', alt='Texto que describa la imagen')\n          p.pe-xl-5.mb-0 El <b>Decreto 1075 del 2015</b> establece una estructura clara para la organización y gestión de las instituciones educativas, dividida en varios aspectos fundamentales:\n\n    .bg-fondo-1.bg-full-width\n      .px-5.pb-md-3.py-4\n\n        .row.mb-4\n          .col-12.col-lg-4.d-none.d-lg-block(data-aos=\"fade-right\")\n            img(src='@/assets/curso/unidad/img-54.png', alt='Texto que describa la imagen')\n          .col-12.col-lg-8(data-aos=\"fade-left\")\n            AcordionA(tipo=\"b\")\n              .div(titulo=\"Autonomía institucional\")\n                p Las instituciones educativas tienen la capacidad de diseñar sus propios proyectos educativos institucionales (PEI), adaptándolos a las particularidades de su comunidad. Esta autonomía permite que las escuelas respondan de manera flexible a las necesidades específicas de sus estudiantes, promoviendo una educación más personalizada y relevante (Decreto 1075, 2015).\n              .div(titulo=\"Planificación curricular\")\n                p La gestión efectiva incluye la elaboración de currículos que no solo cumplan con los estándares académicos, sino que también incorporen valores como la convivencia pacífica, el respeto por la diversidad y la responsabilidad social. Esto asegura que la educación no solo transmita conocimientos, sino que también forme ciudadanos críticos y comprometidos con su entorno.\n              .div(titulo=\"Evaluación y calidad educativa\")\n                p El decreto establece mecanismos de evaluación continua para garantizar que las instituciones mantengan altos estándares de calidad. Esto incluye la evaluación del desempeño docente, la infraestructura educativa y los resultados de aprendizaje de los estudiantes, permitiendo mejoras constantes en el sistema educativo (Decreto 1075, 2015).\n              .div(titulo=\"Participación de la comunidad educativa\")\n                p La inclusión de padres, estudiantes y docentes en la toma de decisiones fortalece la gestión institucional. Los consejos directivos y otros órganos de participación aseguran que todas las voces sean escuchadas, promoviendo una gestión democrática y transparente.\n        p.mb-4 Considere que está construyendo una casa. El currículo sería el plano, la evaluación las herramientas para comprobar que todo está en su lugar, y la promoción, la llave que abre la puerta a un nuevo nivel. ¿Se ha preguntado cómo estas tres partes trabajan juntas en el sistema educativo colombiano, para formar a los ciudadanos del mañana?\n        .row.mb-4\n          .col-10.col-md-8.col-lg-6.mb-4.mx-auto(data-aos=\"fade-right\")\n            div.custom-image-card.rounded-8px\n              img.mb-4(src='@/assets/curso/unidad/img-55.png', alt='Texto que describa la imagen')\n              div.mb-4\n                p.text-small.px-4.text-center.pb-2 El currículo no es solo una lista de materias, es la guía que da sentido al aprendizaje. Según el Decreto 1075 del 2015, las instituciones educativas tienen la libertad de diseñar un currículo que se ajuste a las características de sus estudiantes y sus comunidades, respetando los lineamientos nacionales (Art. 2.3.3.5.1).\n          .col-10.col-md-8.col-lg-6.mb-4.mx-auto(data-aos=\"fade-right\")\n            div.custom-image-card.rounded-8px\n              img.mb-4(src='@/assets/curso/unidad/img-56.png', alt='Texto que describa la imagen')\n              div.mb-4\n                p.text-small.px-4.text-center.pb-2 Esto significa que el aprendizaje puede adaptarse a contextos específicos, como una escuela rural que incluye actividades agrícolas o una urbana que fomenta la innovación tecnológica.\n\n    .row.mb-4\n      .d-none.d-xl-block.col-xl-5.mx-auto.mt-4.mt-xl-0(data-aos=\"fade-right\")\n        img(src='@/assets/curso/unidad/img-57.png', alt='Texto que describa la imagen')  \n      .col-12.col-xl-7.d-flex.flex-column\n        p.mb-4 Cuando se habla de evaluación, con frecuencia se piensa en exámenes y notas, pero va mucho más allá. Según el decreto, evaluar no es solo medir resultados; es un proceso que acompaña el aprendizaje, ayuda a identificar fortalezas y señala las áreas que necesitan más atención (Art. 2.3.3.5.4). \n        p.mb-4 Un ejemplo claro es el uso de proyectos grupales o evaluaciones prácticas que no solo califican conocimientos, sino que también fortalecen habilidades como el trabajo en equipo y la creatividad. Así, puedes reflexionar sobre cómo la evaluación se convierte en una oportunidad para aprender más, en lugar de ser solo un juicio final.\n        .d-flex.align-items-start.bg-azul.p-4(data-aos=\"fade-left\")\n          img.me-3(style=\"width: 90px\" src='@/assets/curso/unidad/img-58.svg', alt='Texto que describa la imagen')\n          .d-flex.flex-column\n            p.pe-xl-3.mb-0 La promoción no se trata de “pasar de grado” por cumplir requisitos básicos, sino de garantizar que cada estudiante esté preparado para asumir los desafíos del siguiente nivel. El decreto contempla estrategias de apoyo para quienes necesitan reforzar aprendizajes antes de avanzar (Art. 2.3.3.5.5).\n\n    p.mb-4 Ahora, visualice una escalera. Cada peldaño representa un grado escolar. <b>¿Qué sucede si uno de esos escalones no está bien construido?</b> Avanzar sin una base sólida puede dificultar el camino. Por eso, la promoción asegura que los estudiantes suban cada escalón con confianza.\n    \n    h3 Reflexione:\n\n    .row.mb-4.mx-0\n      .col-12.col-xl-8.d-flex.align-items-center.bg-morado.p-4.p-xl-5.h-100(data-aos=\"fade-left\")\n        p.mb-0(data-aos=\"fade-up\") Considere que forma parte del equipo que diseña las estrategias de evaluación y promoción para una escuela. <b>¿Qué priorizamos para garantizar que todos los estudiantes tengan una experiencia educativa enriquecedora?</b> Pensar en estas decisiones le ayuda a entender cómo las normas educativas buscan equilibrar calidad e inclusión. \n      .d-none.d-xl-block.col-4.px-0(data-aos=\"fade-left\")\n        img.h-100(src='@/assets/curso/unidad/img-59.png', alt='Texto que describa la imagen')\n\n    .bg-full-width.border-top.actividad(style=\"background-color: #ebf1f5; border-top: 5px solid #f5c145 !important\")\n      .p-4.p-md-5\n        #Actividad                \n          <Actividad :cuestionario=\"cuestionario\"/>\n\n    .bg-full-width.border-top-9-azul\n      .px-4.px-md-5.pt-5.pb-0\n        h2 Material complementario\n        .row\n          .col-12.col-md-6.col-lg-8\n            p.d-flex.my-4\n              img.me-3.mb-auto.mt-1(src='@/assets/componentes/book.svg' :style=\"{'max-width':'16px'}\")\n              a.text-small.text-primary(target=\"_blank\", href=\"https://www.mineducacion.gov.co/\") Ley 1098 de 2006. Código de la Infancia y la Adolescencia.\n            p.d-flex.my-4\n              img.me-3.mb-auto.mt-1(src='@/assets/componentes/book.svg' :style=\"{'max-width':'16px'}\")\n              a.text-small.text-primary(target=\"_blank\", href=\"https://elibro.net/es/ereader/tecnologicadeloriente/230326\") Triana, J. A., et al. (2023). Experiencias innovadoras en la educación superior colombiana. UCC.\n            p.d-flex.my-4\n              img.me-3.mb-auto.mt-1(src='@/assets/componentes/youtube-icon.svg' :style=\"{'max-width':'16px'}\")\n              a.text-small.text-primary(target=\"_blank\", href=\"https://www.youtube.com/watch?v=R4c18dwFw2I\") Magic Markers (2021). Qué es el Estado y cuál es tu papel [Vídeo]\n          .col-12.col-md-6.col-lg-3\n            figure\n              img(src='@/assets/componentes/material-complementario.svg', alt='Imagen de material complementario')\n\n\n</template>\n\n<script>\nimport BannerInterno from '../../components/plantilla/BannerInterno'\nexport default {\n  name: 'Tema3',\n  components: {\n    BannerInterno,\n  },\n  data: () => ({\n    cuestionario: {\n      tema:\n        'Estructura de las Normas en Colombia. Constitución Política de Colombia',\n      titulo: 'Ponte a prueba',\n      introduccion:\n        'Demuestra lo que aprendiste en esta unidad y pon a prueba tus conocimientos.',\n      barajarPreguntas: true,\n      preguntas: [\n        {\n          id: 1,\n          texto:\n            '¿Cuál es el principal objetivo de la Constitución Política de Colombia?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Regular las relaciones internacionales',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto:\n                'Establecer los principios fundamentales del sistema educativo',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'Garantizar los derechos fundamentales de los ciudadanos',\n              esCorrecta: true,\n            },\n            {\n              id: 'd',\n              texto: 'Definir las normas fiscales',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 2,\n          texto:\n            '¿Qué decreto reglamenta la Ley 115 de 1994, según la Constitución?',\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Decreto 1075 de 2015', esCorrecta: false },\n            { id: 'b', texto: 'Decreto 2247 de 1994', esCorrecta: true },\n            { id: 'c', texto: 'Decreto 1290 de 2009', esCorrecta: false },\n            { id: 'd', texto: 'Decreto 1421 de 2017', esCorrecta: false },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 3,\n          texto:\n            '¿Qué principio fundamental garantiza la Constitución Política de Colombia?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'El derecho a la propiedad privada',\n              esCorrecta: false,\n            },\n            { id: 'b', texto: 'El derecho a la educación', esCorrecta: true },\n            { id: 'c', texto: 'El derecho a la salud', esCorrecta: false },\n            { id: 'd', texto: 'El derecho a la movilidad', esCorrecta: false },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 4,\n          texto:\n            '¿Qué se establece en el artículo 67 de la Constitución Política de Colombia?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'La gratuidad de la educación superior',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'El derecho a una educación gratuita y de calidad',\n              esCorrecta: true,\n            },\n            {\n              id: 'c',\n              texto: 'La educación solo para menores de 18 años',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'El financiamiento de la educación privada',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 5,\n          texto: '¿Cuál es la función del Decreto 1075 de 2015?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Reglamentar la Ley 115 de 1994',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Organizar la educación superior en Colombia',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'Establecer los principios fundamentales de la educación',\n              esCorrecta: true,\n            },\n            {\n              id: 'd',\n              texto: 'Reglamentar la administración pública',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n      ],\n      mensaje_final_aprobado: '¡Excelente! Ha superado la actividad.',\n      mensaje_final_reprobado:\n        'Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n  mounted() {\n    this.$nextTick(() => {\n      this.$aosRefresh()\n    })\n  },\n}\n</script>\n\n<style lang=\"sass\">\n.material-complementario\n  padding-top: 3rem\n  border-top: 9px solid $color-sistema-e\n</style>\n"],"sourceRoot":"src/views/curso"}]}